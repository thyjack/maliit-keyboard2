{
	"name": "Maliit Keyboard C++ Dev Environment",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"customizations": {
		"vscode": {
			"settings": {
				"cmake.buildDirectory": "${workspaceFolder}/build",
				"cmake.configureOnOpen": true
			},
			"extensions": [
				"ms-vscode.cpptools",
				"ms-vscode.cmake-tools",
				"twxs.cmake",
				"ms-python.python",
				"llvm-vs-code-extensions.vscode-clangd"
			]
		}
	},
	"remoteUser": "vscode"
}
